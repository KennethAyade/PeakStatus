# Google Gemini API key for the AI chat assistant (server-side only — never
# exposed to the browser). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the chat model (defaults to gemini-flash-latest).
# GEMINI_MODEL=gemini-flash-latest

# Web3Forms access key for the contact form (server-side only). Get a free key
# by entering your inbox at https://web3forms.com — submissions email that inbox.
WEB3FORMS_ACCESS_KEY=
