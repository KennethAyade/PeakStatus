# Google Gemini API key for the AI chat assistant (server-side only — never
# exposed to the browser). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the chat model (defaults to gemini-flash-latest).
# GEMINI_MODEL=gemini-flash-latest

# Web3Forms access key for the contact form. Submitted from the browser, so it
# MUST use the NEXT_PUBLIC_ prefix (Web3Forms keys are meant to be public). Get a
# free key by entering your inbox at https://web3forms.com.
# NOTE: NEXT_PUBLIC_ vars are inlined at BUILD time — redeploy after changing it.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
